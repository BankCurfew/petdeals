---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import productsData from '../../../data/products.json';


export function getStaticPaths() {
  return productsData
    .filter((p: any) => p.slug)
    .map((p: any) => ({
      params: { slug: p.slug },
      props: { product: p },
    }));
}

const { product } = Astro.props;
const price = parseInt(String(product.price).replace(/[^0-9]/g, '')) || 0;
const rating = parseFloat(product.rating) || 0;
const sold = parseInt(String(product.sold).replace(/[^0-9]/g, '')) || 0;
const images = product.images || [];
const affiliateUrl = product.affiliateUrl || product.url || '#';

// Related products (same category, exclude self)
const related = productsData
  .filter((p: any) => p.slug !== product.slug)
  .slice(0, 4)
  .map((p: any) => ({
    name: p.title,
    image: p.images?.[0] || '',
    price: parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0,
    rating: parseFloat(p.rating) || 0,
    sold: parseInt(String(p.sold).replace(/[^0-9]/g, '')) || 0,
    affiliateUrl: p.affiliateUrl || p.url || '#',
  }));

// Schema.org Product markup
const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.title,
  "image": images,
  "description": product.title,
  "offers": {
    "@type": "Offer",
    "url": affiliateUrl,
    "priceCurrency": "THB",
    "price": price,
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Shopee Thailand" },
  },
  ...(rating > 0 ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": rating,
      "bestRating": "5",
      "ratingCount": Math.max(sold, 1),
    }
  } : {}),
};
---

<BaseLayout title={product.title} description={`ซื้อ ${product.title} ราคาดี จาก Shopee — PETDEALS คัดสรรสินค้าสัตว์เลี้ยงคุณภาพ`} image={images[0]}>
  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-400">
    <a href="/" class="hover:text-pet-500">หน้าแรก</a>
    <span class="mx-1">›</span>
    <a href="/deals" class="hover:text-pet-500">สินค้า</a>
    <span class="mx-1">›</span>
    <span class="text-gray-600">{product.title.slice(0, 40)}...</span>
  </nav>

  <div class="max-w-7xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Images -->
      <div>
        <div class="aspect-square bg-surface rounded-xl overflow-hidden mb-3">
          <img src={images[0]} alt={product.title} class="w-full h-full object-cover" />
        </div>
        {images.length > 1 && (
          <div class="grid grid-cols-5 gap-2">
            {images.slice(0, 5).map((img: string) => (
              <div class="aspect-square bg-surface rounded-lg overflow-hidden border border-gray-100">
                <img src={img} alt="" class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Product Info -->
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-gray-900 mb-4 leading-snug">{product.title}</h1>

        <!-- Rating -->
        {rating > 0 && (
          <div class="flex items-center gap-3 mb-4 text-sm">
            <span class="flex items-center gap-1 text-yellow-500 font-semibold">
              ★ {rating.toFixed(1)}
            </span>
            {sold > 0 && <span class="text-gray-400">ขายแล้ว {sold.toLocaleString()} ชิ้น</span>}
          </div>
        )}

        <!-- Price -->
        <div class="bg-pet-50 rounded-xl px-6 py-4 mb-6">
          <span class="text-3xl font-bold text-pet-500">฿{price.toLocaleString()}</span>
        </div>

        <!-- CTA -->
        <a
          href={affiliateUrl}
          target="_blank"
          rel="noopener sponsored"
          class="block w-full text-center bg-pet-500 text-white text-lg font-semibold py-4 rounded-full hover:bg-pet-600 transition-colors shadow-lg shadow-pet-500/20 mb-4"
        >
          🛒 ซื้อเลยที่ Shopee
        </a>

        <p class="text-xs text-gray-400 text-center">
          * ราคาอาจเปลี่ยนแปลง กรุณาตรวจสอบที่ Shopee ก่อนสั่งซื้อ
        </p>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6">สินค้าที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {related.map(p => <ProductCard {...p} />)}
      </div>
    </section>
  )}
</BaseLayout>
