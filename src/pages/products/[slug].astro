---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import PawTrail from '@/components/PawTrail.astro';
import SpeechBubbleCTA from '@/components/SpeechBubbleCTA.astro';
import productsData from '../../../data/products.json';

export function getStaticPaths() {
  return productsData
    .filter((p: any) => p.slug)
    .map((p: any) => ({
      params: { slug: p.slug },
      props: { product: p },
    }));
}

const { product } = Astro.props;
const price = parseInt(String(product.price).replace(/[^0-9]/g, '')) || 0;
const priceHigh = product.price_before_discount ? parseInt(String(product.price_before_discount).replace(/[^0-9]/g, '')) : 0;
const rating = product.rating ? parseFloat(product.rating) : 0;
const reviewCount = product.reviewCount ? parseInt(product.reviewCount) : 0;
const soldRaw = product.sold || '';
const soldStr = typeof soldRaw === 'string' ? soldRaw : (soldRaw > 0 ? soldRaw.toLocaleString() : '');
const localImg = product.localImage || '';
const images = localImg ? [localImg, ...(product.images || []).slice(1)] : (product.images || []);
const affiliateUrl = product.affiliateUrl || product.url || '#';
const brand = product.brand || '';
const brandClean = brand.replace(/\(.*\)/, '').trim();
const shopName = product.shopName || '';
const category = product.category || 'อาหารแมว';
const scrapedAt = product.scrapedAt || '2025-06-29';
const nongDealReview = product.nongDealReview || '';
const reviewCons = product.reviewCons || [];
const lastUpdated = product.lastUpdated || scrapedAt;

// SEO content — use provided or auto-generate
const seoTitle = product.seoTitle || product.title;
const description = product.description || (brandClean
  ? `${seoTitle} จาก ${brandClean} — สินค้ายอดนิยมในหมวด${category} ${rating > 0 ? `ได้รับคะแนน ${rating} ดาว` : ''} ${soldStr ? `ขายแล้ว ${soldStr} ชิ้น` : ''} เช็คราคาล่าสุดและรีวิวจากผู้ซื้อจริง`
  : `${seoTitle} — สินค้าคุณภาพในหมวด${category} เช็คราคาล่าสุดและรีวิวจากผู้ซื้อจริง`
);

// Auto-generate features from available data
const features = product.features || [
  brandClean ? `แบรนด์ ${brandClean} — แบรนด์ที่ได้รับความนิยมในกลุ่ม${category}` : `สินค้าคุณภาพในหมวด${category}`,
  rating >= 4.5 ? `คะแนนรีวิว ${rating} ดาว — ผู้ซื้อให้คะแนนสูง` : rating > 0 ? `คะแนนรีวิว ${rating} ดาว จากผู้ซื้อจริง` : 'สินค้ายอดนิยมจากร้านค้าชั้นนำ',
  soldStr ? `ขายแล้ว ${soldStr} ชิ้น — เป็นที่นิยมในหมู่ทาสแมวและทาสหมา` : 'สินค้าแนะนำจาก PetzDeals',
  `ราคาเริ่มต้น ฿${price.toLocaleString()} — คุ้มค่าสำหรับเจ้านาย`,
  shopName ? `จำหน่ายโดย ${shopName} — ร้านค้าที่เชื่อถือได้` : 'จากร้านค้าที่ผ่านการคัดสรร',
];

// Auto-generate specs table
const specs = product.specs || {
  'แบรนด์': brandClean || '-',
  'หมวดหมู่': category,
  'ราคา': `฿${price.toLocaleString()}${priceHigh > price ? ` - ฿${priceHigh.toLocaleString()}` : ''}`,
  ...(rating > 0 ? {'คะแนนรีวิว': `${rating} / 5 ดาว`} : {}),
  ...(reviewCount > 0 ? {'จำนวนรีวิว': `${reviewCount} รีวิว`} : {}),
  ...(soldStr ? {'ยอดขาย': soldStr} : {}),
  ...(shopName ? {'ร้านค้า': shopName} : {}),
};

// Auto-generate FAQ
const categoryFaqs: Record<string, {q: string, a: string}[]> = {
  'อาหารแมว': [
    { q: `${brandClean || 'อาหารแมว'}ยี่ห้อนี้ดีไหม?`, a: `${brandClean || 'สินค้านี้'}ได้รับคะแนน ${rating > 0 ? rating + ' ดาว' : 'ดี'} จากผู้ซื้อจริง ${reviewCount > 0 ? reviewCount + ' รีวิว' : ''} ${soldStr ? 'ขายแล้ว ' + soldStr + ' ชิ้น' : ''} เหมาะสำหรับแมวทุกสายพันธุ์ ควรสังเกตส่วนผสมและเลือกตามวัยของน้องเหมียว` },
    { q: `อาหารแมว ${brandClean || ''} เหมาะกับแมวอายุเท่าไหร่?`, a: 'ควรอ่านรายละเอียดบนฉลากสินค้าเพื่อเช็คว่าเหมาะกับแมววัยไหน ส่วนใหญ่แบ่งเป็นลูกแมว (Kitten), แมวโต (Adult 1-7 ปี), และแมวสูงวัย (Senior 7+ ปี)' },
    { q: 'เปลี่ยนอาหารแมวต้องทำอย่างไร?', a: 'ควรค่อยๆ ผสมอาหารใหม่กับอาหารเดิมในสัดส่วน 25:75 แล้วค่อยๆ เพิ่มอาหารใหม่ทุก 2-3 วัน ใช้เวลาประมาณ 7-10 วัน เพื่อไม่ให้น้องเหมียวท้องเสีย' },
  ],
  'อาหารเปียก': [
    { q: `อาหารเปียก ${brandClean || ''} เปิดแล้วเก็บได้นานแค่ไหน?`, a: 'อาหารเปียกเปิดแล้วควรเก็บในตู้เย็นและใช้ภายใน 24-48 ชั่วโมง ไม่ควรทิ้งไว้ที่อุณหภูมิห้องนานเกิน 2 ชั่วโมง' },
    { q: 'ให้อาหารเปียกอย่างเดียวได้ไหม?', a: 'ได้ถ้าเป็นอาหารเปียกแบบ Complete & Balanced แต่แนะนำให้สลับกับอาหารเม็ดเพื่อช่วยขัดฟันและให้สารอาหารครบถ้วน' },
    { q: 'น้องเหมียวกินแต่อาหารเปียก ไม่ยอมกินเม็ดทำอย่างไร?', a: 'ลองผสมอาหารเม็ดกับอาหารเปียกทีละน้อย หรือลองราดน้ำซุปไก่ต้มบนอาหารเม็ดให้มีกลิ่นหอม ค่อยๆ ลดปริมาณอาหารเปียกลง' },
  ],
  'ขนมแมว': [
    { q: `ขนมแมว ${brandClean || ''} ให้ได้วันละกี่ชิ้น?`, a: 'ขนมแมวควรให้ไม่เกิน 10% ของแคลอรี่ทั้งวัน โดยทั่วไปประมาณ 2-4 ซองต่อวัน ขึ้นกับน้ำหนักตัวของน้องเหมียว' },
    { q: 'ขนมแมวกินแทนอาหารหลักได้ไหม?', a: 'ไม่ควร ขนมแมวเป็นอาหารเสริมไม่ใช่อาหารหลัก สารอาหารไม่ครบถ้วน ควรให้เป็นรางวัลหรือของว่างเท่านั้น' },
    { q: 'น้องเหมียวติดขนมแมวไม่ยอมกินอาหารหลักทำอย่างไร?', a: 'ลดปริมาณขนมลงทีละน้อย และให้ขนมหลังกินอาหารหลักเสร็จเท่านั้น อย่าให้ขนมก่อนมื้ออาหาร' },
  ],
  'ทรายแมว': [
    { q: `ทรายแมว ${brandClean || ''} ใช้ได้กี่วัน?`, a: 'ขึ้นกับจำนวนแมวและปริมาณทราย โดยทั่วไปทราย 10 ลิตร ใช้ได้ประมาณ 2-3 สัปดาห์สำหรับแมว 1 ตัว ควรตักก้อนออกทุกวันและเปลี่ยนทรายทั้งถาดทุก 2-4 สัปดาห์' },
    { q: 'ทรายแมวแบบไหนดีที่สุด?', a: 'ขึ้นกับความชอบของเจ้านายและทาส ทรายเบนโทไนท์จับตัวดีดูดกลิ่นเก่ง ทรายเต้าหู้ทิ้งชักโครกได้ ทรายคริสตัลดูดซับดีเปลี่ยนน้อย ลองให้น้องเหมียวเลือกเอง' },
    { q: 'เปลี่ยนยี่ห้อทรายแมวต้องทำอย่างไร?', a: 'ค่อยๆ ผสมทรายใหม่กับทรายเดิมในสัดส่วน 30:70 แล้วเพิ่มทรายใหม่ขึ้นทุก 3-5 วัน แมวบางตัวอาจไม่ยอมใช้ถ้าเปลี่ยนทันที' },
  ],
  'สุนัข': [
    { q: `อาหารสุนัข ${brandClean || ''} เหมาะกับสุนัขพันธุ์ไหน?`, a: `${brandClean || 'อาหารสุนัขนี้'}เหมาะสำหรับสุนัขทุกสายพันธุ์ ควรเลือกขนาดเม็ดตามขนาดตัวสุนัข (เล็ก/กลาง/ใหญ่) และสูตรตามช่วงวัย` },
    { q: 'สุนัขควรกินอาหารวันละกี่มื้อ?', a: 'ลูกสุนัข 2-6 เดือนควรกิน 3-4 มื้อ สุนัขโต 6 เดือนขึ้นไปกิน 2 มื้อ ปริมาณตามน้ำหนักตัวที่ระบุบนฉลาก' },
    { q: 'อาหารสุนัขกับอาหารแมวใช้แทนกันได้ไหม?', a: 'ไม่ควร สุนัขและแมวต้องการสารอาหารต่างกัน แมวต้องการทอรีนและอะราคิโดนิกมากกว่า อาหารสุนัขไม่มีสารเหล่านี้เพียงพอ' },
  ],
};
const faq = product.faq || categoryFaqs[category] || categoryFaqs['อาหารแมว'];

// Auto-generate FAQ schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const related = productsData
  .filter((p: any) => p.slug && p.slug !== product.slug)
  .filter((p: any) => p.category === category)
  .slice(0, 4)
  .map((p: any) => ({
    name: p.title,
    image: p.localImage || `/products/${p.slug}.webp`,
    price: parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0,
    rating: p.rating ? parseFloat(p.rating) : undefined,
    sold: p.sold || '',
    affiliateUrl: p.affiliateUrl || p.url || '#',
    slug: p.slug,
    lastUpdated: p.lastUpdated || p.scrapedAt,
    category: p.category,
  }));

const lastUpdatedFormatted = new Date(lastUpdated).toLocaleDateString('th-TH', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": seoTitle,
  "image": images,
  "description": description,
  "brand": brandClean ? { "@type": "Brand", "name": brandClean } : undefined,
  "offers": {
    "@type": "Offer",
    "url": Astro.url.href,
    "priceCurrency": "THB",
    "price": price,
    ...(priceHigh > price ? { "highPrice": priceHigh } : {}),
    "availability": "https://schema.org/InStock",
  },
  ...(rating > 0 ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": rating,
      "bestRating": "5",
      "ratingCount": reviewCount || 10,
    }
  } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "หน้าแรก", "item": new URL("/", Astro.site).href },
    { "@type": "ListItem", "position": 2, "name": category, "item": new URL("/deals", Astro.site).href },
    { "@type": "ListItem", "position": 3, "name": seoTitle },
  ],
};

// Rating star breakdown (approximate from rating + reviewCount)
const starBreakdown = rating > 0 && reviewCount > 0 ? (() => {
  const total = reviewCount;
  const avg = rating;
  const s5 = Math.round(total * (avg - 4) * 0.8);
  const s4 = Math.round(total * 0.15);
  const s3 = Math.round(total * 0.03);
  const s2 = Math.round(total * 0.01);
  const s1 = Math.max(0, total - s5 - s4 - s3 - s2);
  return [
    { stars: 5, count: Math.max(0, s5), pct: Math.round((Math.max(0, s5) / total) * 100) },
    { stars: 4, count: s4, pct: Math.round((s4 / total) * 100) },
    { stars: 3, count: s3, pct: Math.round((s3 / total) * 100) },
    { stars: 2, count: s2, pct: Math.round((s2 / total) * 100) },
    { stars: 1, count: Math.max(0, s1), pct: Math.round((Math.max(0, s1) / total) * 100) },
  ];
})() : null;
---

<BaseLayout title={seoTitle} description={description} image={localImg || images[0]}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-400">
    <a href="/" class="hover:text-pet-500">หน้าแรก</a>
    <span class="mx-1">›</span>
    <a href="/deals" class="hover:text-pet-500">{category}</a>
    <span class="mx-1">›</span>
    <span class="text-gray-600">{seoTitle.slice(0, 50)}{seoTitle.length > 50 ? '...' : ''}</span>
  </nav>

  <article class="max-w-7xl mx-auto px-4 py-6">
    <!-- Product Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Images -->
      <div>
        <div class="aspect-square bg-surface rounded-xl overflow-hidden mb-3">
          <img src={localImg || images[0]} alt={seoTitle} title={seoTitle} width="800" height="800" class="w-full h-full object-cover" fetchpriority="high" />
        </div>
        {images.length > 1 && (
          <div class="grid grid-cols-5 gap-2">
            {images.slice(0, 5).map((img: string, i: number) => (
              <div class="aspect-square bg-surface rounded-lg overflow-hidden border border-gray-100">
                <img src={img} alt={`${seoTitle} - ภาพที่ ${i + 2}`} title={seoTitle} width="200" height="200" class="w-full h-full object-cover" loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-gray-900 mb-4 leading-snug">{seoTitle}</h1>

        {(rating > 0 || soldStr || brandClean) && (
          <div class="flex items-center flex-wrap gap-3 mb-4 text-sm">
            {rating > 0 && (
              <span class="flex items-center gap-1 text-star font-semibold">★ {rating.toFixed(1)}</span>
            )}
            {reviewCount > 0 && <span class="text-gray-400">({reviewCount} รีวิว)</span>}
            {soldStr && <span class="text-gray-400">ขายแล้ว {soldStr}</span>}
            {brandClean && <span class="text-pet-500 font-medium">{brandClean}</span>}
          </div>
        )}

        <div class="bg-pet-50 rounded-xl px-6 py-4 mb-6">
          <span class="text-3xl font-bold text-pet-600">฿{price.toLocaleString()}</span>
          {priceHigh > price && (
            <span class="text-lg text-gray-400 line-through ml-3">฿{priceHigh.toLocaleString()}</span>
          )}
        </div>

        <p class="text-gray-600 leading-relaxed mb-6">{description}</p>

        <a
          href={affiliateUrl}
          target="_blank"
          rel="noopener sponsored"
          class="block w-full text-center bg-cta-500 text-white text-lg font-semibold py-4 rounded-full hover:bg-cta-600 transition-colors shadow-lg shadow-cta-500/20 mb-4"
          data-affiliate="true"
          data-product-name={product.title}
          data-product-price={price}
          onclick={`window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'affiliate_click',product_name:'${product.title.replace(/'/g,"\\'")}',product_price:${price},affiliate_url:'${affiliateUrl}'})`}
        >
          เช็คราคาให้เจ้านาย
        </a>

        <p class="text-xs text-gray-400 text-center mb-1">* ราคาอาจเปลี่ยนแปลง กรุณาตรวจสอบราคาล่าสุดก่อนสั่งซื้อ</p>
        <p class="text-xs text-gray-300 text-center">อัพเดทล่าสุด: {lastUpdatedFormatted}</p>
      </div>
    </div>

    <!-- H2: จุดเด่น -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">จุดเด่นของ {brandClean || 'สินค้า'}</h2>
      <ul class="space-y-3">
        {features.map((f: string) => (
          <li class="flex items-start gap-3">
            <span class="text-pet-500 mt-0.5 shrink-0">✓</span>
            <span class="text-gray-600">{f}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- H2: ข้อมูลจำเพาะ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ข้อมูลจำเพาะ</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <tbody>
            {Object.entries(specs).map(([key, value], i) => (
              <tr class={i % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
                <td class="px-4 py-3 font-medium text-gray-700 w-1/3">{key}</td>
                <td class="px-4 py-3 text-gray-600">{value as string}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- H2: น้องดีลรีวิว -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">น้องดีลรีวิว</h2>

      {starBreakdown ? (
        <div class="bg-surface rounded-xl p-6 mb-6">
          <div class="flex items-center gap-6 mb-4">
            <div class="text-center">
              <div class="text-4xl font-bold text-gray-900">{rating.toFixed(1)}</div>
              <div class="text-star text-sm mt-1">{'★'.repeat(Math.round(rating))}{'☆'.repeat(5 - Math.round(rating))}</div>
              <div class="text-xs text-gray-400 mt-1">{reviewCount} รีวิว</div>
            </div>
            <div class="flex-1 space-y-1.5">
              {starBreakdown.map(s => (
                <div class="flex items-center gap-2 text-xs">
                  <span class="w-6 text-right text-gray-500">{s.stars}★</span>
                  <div class="flex-1 bg-gray-200 rounded-full h-2">
                    <div class="bg-star rounded-full h-2" style={`width: ${s.pct}%`}></div>
                  </div>
                  <span class="w-8 text-right text-gray-400">{s.pct}%</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-surface rounded-xl p-6 mb-6 text-center">
          <p class="text-gray-400 text-sm">ยังไม่มีรีวิวจากผู้ซื้อ</p>
        </div>
      )}

      <div class="bg-cream rounded-xl p-5 border border-yellow-100">
        <div class="flex items-start gap-3">
          <img src="/brand/nong-deal-bossy.webp" alt="น้องดีล" class="w-10 h-10 rounded-full object-cover shrink-0" />
          <div>
            <p class="font-semibold text-gray-800 text-sm mb-1">💬 น้องดีลรีวิว</p>
            <p class="text-gray-600 text-sm leading-relaxed">
              {nongDealReview
                ? nongDealReview
                : rating >= 4.5
                ? `ข้าให้ผ่าน! ${brandClean || 'สินค้านี้'}ได้คะแนน ${rating} ดาว ${soldStr ? 'ขายไป ' + soldStr + ' ชิ้นแล้ว' : ''} — ทาสหลายคนยืนยันว่าเจ้านายชอบ เหมียว~`
                : rating >= 4.0
                ? `พอใช้ได้เจ้าทาส ${brandClean || 'สินค้านี้'}ได้ ${rating} ดาว ราคาเริ่ม ฿${price.toLocaleString()} คุ้มค่าพอสมควร ลองดูรีวิวจากทาสคนอื่นก่อนตัดสินใจ`
                : `ข้ายังไม่มีข้อมูลรีวิวมากพอ ลองเช็คราคาและรีวิวเพิ่มเติมก่อนซื้อให้ข้านะเจ้าทาส`
              }
            </p>
          </div>
        </div>
      </div>

      {reviewCons.length > 0 && (
        <div class="mt-4 bg-surface rounded-xl p-5">
          <p class="font-semibold text-gray-700 text-sm mb-2">📌 จุดสังเกต</p>
          <ul class="space-y-1.5">
            {reviewCons.map((c: string) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-coral-400 shrink-0">•</span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <PawTrail />

    <!-- Secondary CTA -->
    <div class="mb-10 text-center">
      <SpeechBubbleCTA href={affiliateUrl} />
    </div>

    <!-- H2: คำถามที่พบบ่อย -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-6">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faq.map((f: any) => (
          <div class="border border-gray-100 rounded-xl p-5">
            <h3 class="font-semibold text-gray-800 mb-2">{f.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <PawTrail count={7} />

    <!-- H2: สินค้าที่คล้ายกัน -->
    {related.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-gray-900 mb-6">สินค้าที่คล้ายกัน</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {related.map(p => <ProductCard {...p} />)}
        </div>
      </section>
    )}
  </article>

  <!-- Sticky bottom CTA bar (mobile conversion) -->
  <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-2 flex items-center justify-between z-40 shadow-[0_-2px_10px_rgba(0,0,0,0.05)] sm:hidden">
    <div>
      <div class="text-lg font-bold text-rose-500">฿{price.toLocaleString()}</div>
      {priceHigh > price && (
        <div class="text-xs text-gray-400 line-through">฿{priceHigh.toLocaleString()}</div>
      )}
    </div>
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener sponsored"
      class="bg-emerald-500 text-white font-semibold px-6 py-2.5 rounded-full text-sm hover:bg-emerald-600 transition-colors"
      data-affiliate="true"
      data-product-name={product.title}
    >
      เช็คราคาบน Shopee
    </a>
  </div>
  <div class="h-16 sm:hidden" />
</BaseLayout>
