---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import PawTrail from '@/components/PawTrail.astro';
import categoriesData from '../../../data/categories.json';
import productsData from '../../../data/products.json';

export function getStaticPaths() {
  return categoriesData.map((cat: any) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const products = productsData
  .filter((p: any) => p.slug && p.category === category.dataCategory)
  .map((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const beforeDiscount = p.originalPrice ? parseInt(String(p.originalPrice).replace(/[^0-9]/g, '')) : 0;
    const hasRealDiscount = beforeDiscount > price;
    return {
      name: p.title,
      image: p.localImage || `/products/${p.slug}.webp`,
      price,
      originalPrice: hasRealDiscount ? beforeDiscount : undefined,
      discount: hasRealDiscount ? Math.round((1 - price / beforeDiscount) * 100) : 0,
      rating: p.rating ? parseFloat(p.rating) : undefined,
      sold: p.sold || '',
      affiliateUrl: p.affiliateUrl || p.url || '#',
      category: p.category,
      lastUpdated: p.lastUpdated || p.scrapedAt,
      slug: p.slug,
    };
  });

const hasProducts = products.length > 0;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "หน้าแรก", "item": "https://petzdeals.com/" },
    { "@type": "ListItem", "position": 2, "name": category.name },
  ],
};
---

<BaseLayout title={`${category.name} — ${category.nameEn} | PetzDeals`} description={category.description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-400">
    <a href="/" class="hover:text-pet-500">หน้าแรก</a>
    <span class="mx-1">›</span>
    <span class="text-gray-600">{category.name}</span>
  </nav>

  <section class="max-w-7xl mx-auto px-4 py-8">
    <!-- Category Header -->
    <div class="bg-cream rounded-2xl p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">{category.emoji}</span>
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900">{category.name}</h1>
          <p class="text-sm text-gray-400">{category.nameEn}</p>
        </div>
      </div>
      <p class="text-gray-600 leading-relaxed">{category.description}</p>
      {hasProducts && (
        <p class="text-sm text-pet-500 font-medium mt-2">{products.length} สินค้า</p>
      )}
    </div>

    {hasProducts ? (
      <>
        <!-- Sort/filter bar -->
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <h2 class="text-lg font-bold text-gray-900">{category.emoji} {category.name}ทั้งหมด</h2>
          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-400" id="count-label">{products.length} รายการ</span>
            <select id="sort-select" class="text-sm border border-gray-200 rounded-lg px-2 py-1 bg-white text-gray-600 focus:outline-none focus:border-teal-400">
              <option value="discount">ลดมาก → น้อย</option>
              <option value="price-low">ราคาต่ำ → สูง</option>
              <option value="price-high">ราคาสูง → ต่ำ</option>
              <option value="rating">คะแนนสูงสุด</option>
              <option value="name">ตัวอักษร</option>
            </select>
          </div>
        </div>

        <div id="product-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {products.map(p => (
            <div data-product-name={p.name} data-price={p.price} data-discount={p.discount || 0} data-rating={p.rating || 0}>
              <ProductCard {...p} />
            </div>
          ))}
        </div>

        <script>
          const grid = document.getElementById('product-grid')!;
          const select = document.getElementById('sort-select') as HTMLSelectElement;
          select?.addEventListener('change', () => {
            const cards = [...grid.children] as HTMLElement[];
            const key = select.value;
            cards.sort((a, b) => {
              if (key === 'discount') return +(b.dataset.discount || 0) - +(a.dataset.discount || 0);
              if (key === 'price-low') return +(a.dataset.price || 0) - +(b.dataset.price || 0);
              if (key === 'price-high') return +(b.dataset.price || 0) - +(a.dataset.price || 0);
              if (key === 'rating') return +(b.dataset.rating || 0) - +(a.dataset.rating || 0);
              if (key === 'name') return (a.dataset.productName || '').localeCompare(b.dataset.productName || '', 'th');
              return 0;
            });
            cards.forEach(c => grid.appendChild(c));
          });
        </script>
      </>
    ) : (
      <div class="text-center py-16">
        <img src="/brand/nong-deal-bossy.webp" alt="น้องดีล" class="w-24 h-24 mx-auto rounded-full object-cover mb-4 opacity-50" />
        <p class="text-gray-400 text-lg mb-2">ยังไม่มีสินค้าในหมวดนี้เจ้าทาส</p>
        <p class="text-gray-300 text-sm mb-6">น้องดีลกำลังคัดสินค้ามาให้เจ้านาย รอหน่อยนะ!</p>
        <a href="/" class="inline-block bg-cta-500 text-white px-6 py-2 rounded-full font-medium hover:bg-cta-600 transition-colors">
          ดูสินค้าอื่น
        </a>
      </div>
    )}

    <PawTrail count={7} />

    <!-- SEO content -->
    <div class="max-w-3xl mx-auto mt-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">เกี่ยวกับ{category.name}</h2>
      <div class="prose prose-gray text-sm leading-relaxed">
        <p>{category.description} PetzDeals คัดสรรสินค้าคุณภาพดีมาให้ทาสแมวและทาสหมาโดยเฉพาะ เช็คราคาล่าสุด เปรียบเทียบรีวิว อัพเดททุกวัน</p>
      </div>
    </div>
  </section>
</BaseLayout>
