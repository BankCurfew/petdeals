---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero77 from '@/components/Hero77.astro';
import CategoryPills from '@/components/CategoryPills.astro';
import ProductCard from '@/components/ProductCard.astro';
import PawTrail from '@/components/PawTrail.astro';

import productsData from '../../data/products.json';

const products = productsData
  .filter((p: any) => p.slug)
  .map((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const maxPrice = parseInt(String(p.priceMax).replace(/[^0-9]/g, '')) || 0;
    return {
      name: p.title,
      image: p.images?.[0] || 'https://placehold.co/400x400/F0FDFA/14B8A6?text=Product',
      price,
      originalPrice: maxPrice > price ? maxPrice : undefined,
      discount: maxPrice > price ? Math.round((1 - price / maxPrice) * 100) : 0,
      rating: p.rating ? parseFloat(p.rating) : undefined,
      sold: p.sold || '',
      affiliateUrl: p.affiliateUrl || p.url || '#',
      category: p.category || 'อาหารแมว',
      lastUpdated: p.lastUpdated || p.scrapedAt || '2025-06-28',
      slug: p.slug,
    };
  });
---

<BaseLayout title="PetzDeals — รวมดีลอุปกรณ์สัตว์เลี้ยง คัดมาให้ทาสแมวและทาสหมา">
  <!-- 7.7 Sale Hero -->
  <Hero77 />

  <!-- Category Pills -->
  <section class="max-w-7xl mx-auto mt-8">
    <CategoryPills />
  </section>

  <PawTrail />

  <!-- Featured Products -->
  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">สินค้าแนะนำสำหรับเจ้านาย</h2>
      <a href="/deals" class="text-sm text-pet-500 hover:text-pet-600 font-medium">ดูทั้งหมด →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {products.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
  </section>

  <PawTrail count={7} />

  <!-- SEO Content -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4">PetzDeals — แหล่งรวมดีลอุปกรณ์สัตว์เลี้ยงสำหรับทาสแมวและทาสหมา</h2>
    <div class="prose prose-gray text-sm leading-relaxed">
      <p>PetzDeals คัดสรรอุปกรณ์สัตว์เลี้ยงคุณภาพดีให้ทาสแมวและทาสหมาตัวจริง ทั้งอาหารน้องเหมียว อาหารน้องหมา ของเล่น ที่นอน อุปกรณ์อาบน้ำ และผลิตภัณฑ์ดูแลสุขภาพ พร้อมส่วนลดพิเศษอัพเดททุกวัน</p>
      <p>เราช่วยทาสแมวและทาสหมาประหยัดเวลาในการเลือกของให้เจ้านาย โดยคัดเฉพาะสินค้ารีวิวดี ยอดขายสูง และราคาคุ้มค่าที่สุด</p>
    </div>
  </section>
</BaseLayout>
