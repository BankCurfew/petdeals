---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PawTrail from '@/components/PawTrail.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="บทความสำหรับทาสแมวและทาสหมา" description="รวมบทความรีวิว แนะนำสินค้า เคล็ดลับดูแลน้องเหมียวและน้องหมา โดยน้องดีล">
  <nav class="max-w-4xl mx-auto px-4 py-3 text-sm text-gray-400">
    <a href="/" class="hover:text-pet-500">หน้าแรก</a>
    <span class="mx-1">›</span>
    <span class="text-gray-600">บทความ</span>
  </nav>

  <section class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">บทความสำหรับทาสแมวและทาสหมา</h1>
    <p class="text-gray-500 mb-8">รีวิว แนะนำ เคล็ดลับ — โดยน้องดีล 🐾 แมวจอมบงการ</p>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.id}/`} class="block group bg-white rounded-xl border border-gray-100 p-5 hover:shadow-md hover:border-pet-200 transition-all">
          <div class="flex items-start gap-4">
            <img src="/brand/nong-deal-bossy.webp" alt="" class="w-12 h-12 rounded-full object-cover shrink-0 mt-1" />
            <div class="flex-1 min-w-0">
              <h2 class="text-lg font-bold text-gray-900 group-hover:text-pet-500 transition-colors mb-1 line-clamp-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 line-clamp-2 mb-2">{post.data.description}</p>
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span>{post.data.author}</span>
                <span>•</span>
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.category && (
                  <>
                    <span>•</span>
                    <span class="bg-pet-50 text-pet-600 px-2 py-0.5 rounded-full">{post.data.category}</span>
                  </>
                )}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <PawTrail count={7} />
  </section>
</BaseLayout>
