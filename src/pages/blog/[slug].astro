---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import PawTrail from '@/components/PawTrail.astro';
import { getCollection, render } from 'astro:content';
import productsData from '../../../data/products.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const relatedProducts = productsData
  .filter((p: any) => p.slug)
  .slice(0, 4)
  .map((p: any) => ({
    name: p.title,
    image: p.images?.[0] || '',
    price: parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0,
    rating: p.rating ? parseFloat(p.rating) : undefined,
    sold: p.sold || '',
    affiliateUrl: p.affiliateUrl || p.url || '#',
    slug: p.slug,
    lastUpdated: p.lastUpdated || p.scrapedAt,
    category: p.category,
  }));

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "author": { "@type": "Organization", "name": "PetzDeals" },
  "publisher": { "@type": "Organization", "name": "PetzDeals", "url": "https://petzdeals.com" },
};

const dateFormatted = new Date(post.data.date).toLocaleDateString('th-TH', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <nav class="max-w-4xl mx-auto px-4 py-3 text-sm text-gray-400">
    <a href="/" class="hover:text-pet-500">หน้าแรก</a>
    <span class="mx-1">›</span>
    <a href="/blog" class="hover:text-pet-500">บทความ</a>
    <span class="mx-1">›</span>
    <span class="text-gray-600">{post.data.title.slice(0, 40)}...</span>
  </nav>

  <article class="max-w-[700px] mx-auto px-5 py-8">
    <header class="mb-10">
      <!-- Sale banner for 7.7 article -->
      {post.id.includes('7-7') && (
        <div class="rounded-2xl overflow-hidden mb-6 shadow-lg">
          <img src="/brand/77-mega-sale-banner.png" alt="7.7 Mega Pet Sale" class="w-full h-auto" />
        </div>
      )}

      <!-- Byline card -->
      <div class="flex items-center gap-3 bg-cream rounded-xl p-4 border border-yellow-100 mb-6">
        <img src="/brand/nong-deal-bossy.png" alt="น้องดีล" class="w-12 h-12 rounded-full object-cover" />
        <div>
          <p class="font-semibold text-gray-800 text-sm">{post.data.author}</p>
          <p class="text-xs text-gray-400">ทีมรีวิว PetzDeals · {dateFormatted}</p>
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-black text-gray-900 leading-tight mb-4">{post.data.title}</h1>
      <p class="text-lg text-gray-500 leading-relaxed">{post.data.description}</p>
    </header>

    <div class="blog-article prose prose-gray max-w-none">
      <Content />
    </div>

    <PawTrail count={7} />

    <section class="mt-12 pt-8 border-t border-gray-100">
      <h2 class="text-xl font-bold text-gray-900 mb-6">สินค้าแนะนำสำหรับเจ้านาย</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {relatedProducts.map(p => <ProductCard {...p} />)}
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .blog-article p {
    font-size: 17px;
    line-height: 2.0;
    margin-bottom: 1.5em;
    color: #374151;
  }
  .blog-article h2 {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.4;
    margin-top: 48px;
    margin-bottom: 16px;
    color: #111827;
    padding-bottom: 8px;
    border-bottom: 2px solid #E5E7EB;
  }
  .blog-article h3 {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    margin-top: 32px;
    margin-bottom: 12px;
    color: #1F2937;
  }
  .blog-article li {
    font-size: 17px;
    line-height: 1.8;
    margin-bottom: 8px;
  }
  .blog-article img {
    border-radius: 12px;
    margin: 32px 0;
  }
  .blog-article table {
    font-size: 14px;
    width: 100%;
    margin: 24px 0;
  }
  .blog-article th {
    background: #14B8A6;
    color: white;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
  }
  .blog-article td {
    padding: 10px 14px;
    border-bottom: 1px solid #E5E7EB;
  }
  .blog-article tr:nth-child(even) {
    background: #F9FAFB;
  }
  .blog-article blockquote {
    background: #F0FDFA;
    border-left: 4px solid #14B8A6;
    border-radius: 8px;
    padding: 16px 20px;
    margin: 24px 0;
    font-style: normal;
  }
  .blog-article a {
    color: #0D9488;
    text-decoration: none;
    font-weight: 500;
  }
  .blog-article a:hover {
    text-decoration: underline;
  }
  .blog-article hr {
    margin: 48px 0;
    border-color: #E5E7EB;
  }
  .blog-article strong {
    color: #111827;
  }
</style>
