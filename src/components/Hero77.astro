---
import CountdownTimer from './CountdownTimer.astro';
import productsData from '../../data/products.json';

const saleEnd = '2026-07-08T00:00:00+07:00';

const topDeals = productsData
  .filter((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const max = parseInt(String(p.priceMax).replace(/[^0-9]/g, '')) || 0;
    return max > price && p.slug;
  })
  .map((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const max = parseInt(String(p.priceMax).replace(/[^0-9]/g, '')) || 0;
    return { ...p, priceNum: price, maxNum: max, discount: Math.round((1 - price / max) * 100) };
  })
  .sort((a: any, b: any) => b.discount - a.discount)
  .slice(0, 4);

const maxDiscount = topDeals.length > 0 ? topDeals[0].discount : 50;
---

<section class="hero-77-punchy relative overflow-hidden">
  <!-- Banner image background -->
  <div class="absolute inset-0">
    <img src="/brand/77-mega-sale-banner.webp" alt="7.7 Mega Pet Sale — ลดสูงสุด 80% อุปกรณ์สัตว์เลี้ยง" title="PetzDeals 7.7 Mega Sale" width="1200" height="400" class="w-full h-full object-cover object-top opacity-30 md:opacity-20" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-red-600/60 to-red-700/90"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pt-8 pb-6 md:pt-12 md:pb-8 relative z-10">
    <!-- Flash badge -->
    <div class="text-center mb-3">
      <span class="badge-mega inline-block">FLASH SALE เริ่มแล้ว!</span>
    </div>

    <!-- 7.7 + headline -->
    <div class="text-center mb-4">
      <div class="sale-number select-none">7.7</div>
      <h2 class="text-2xl md:text-4xl font-black text-white -mt-1 mb-1 tracking-tight drop-shadow-lg">
        MEGA PET SALE
      </h2>
      <p class="text-xl md:text-2xl text-white font-bold">
        ลดสูงสุด <span class="text-yellow-300 text-3xl md:text-4xl font-black drop-shadow">{maxDiscount}%</span>
      </p>
    </div>

    <!-- Countdown — RED boxes -->
    <div class="text-center mb-6">
      <CountdownTimer targetDate={saleEnd} label="⏰ ดีลหมดใน" />
    </div>

    <!-- Flash deal preview -->
    {topDeals.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 max-w-3xl mx-auto mb-6">
        {topDeals.map((deal: any) => (
          <a href={`/products/${deal.slug}`} class="bg-white/15 backdrop-blur rounded-xl p-2.5 text-center hover:bg-white/25 transition-colors group border border-white/10">
            <div class="aspect-square rounded-lg overflow-hidden bg-white/10 mb-1.5 relative">
              <img src={deal.images?.[0]} alt={deal.title} title={deal.title} width="300" height="300" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" decoding="async" />
              <span class="absolute top-1 right-1 bg-yellow-400 text-red-700 text-[10px] font-black px-1.5 py-0.5 rounded-full">-{deal.discount}%</span>
            </div>
            <div class="sale-price text-base">฿{deal.priceNum.toLocaleString()}</div>
            <div class="original-price">฿{deal.maxNum.toLocaleString()}</div>
          </a>
        ))}
      </div>
    )}

    <!-- CTA → article -->
    <div class="text-center mb-4">
      <a href="/blog/7-7-mega-sale-2026/" class="inline-block bg-yellow-400 text-red-700 px-10 py-4 rounded-full font-black text-lg hover:bg-yellow-300 transition-all shadow-lg shadow-yellow-400/40 hover:scale-105 active:scale-95">
        ดูดีล 7.7 ทั้งหมด →
      </a>
    </div>

    <!-- Mascot -->
    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-black/20 backdrop-blur rounded-full px-4 py-2 text-white text-sm">
        <img src="/brand/nong-deal-bossy.webp" alt="น้องดีล" class="w-8 h-8 rounded-full object-cover" />
        <span>น้องดีล: "ดีลเดือด! จงกดเดี๋ยวนี้ เหมี๊ยว!"</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-77-punchy {
    background: linear-gradient(135deg, #DC2626 0%, #EA580C 50%, #FBBF24 100%);
  }
  .sale-number {
    font-size: clamp(90px, 22vw, 160px);
    font-weight: 900;
    color: white;
    text-shadow: 0 6px 30px rgba(0,0,0,0.4), 0 2px 4px rgba(0,0,0,0.3), 0 0 80px rgba(251,191,36,0.3);
    line-height: 0.85;
    letter-spacing: -0.03em;
  }
  .badge-mega {
    background: #FBBF24;
    color: #DC2626;
    font-weight: 900;
    font-size: 13px;
    padding: 6px 16px;
    border-radius: 999px;
    animation: pulse-badge 1.5s infinite;
    letter-spacing: 0.05em;
  }
  .sale-price {
    color: #FEF08A;
    font-weight: 900;
  }
  .original-price {
    text-decoration: line-through;
    color: rgba(255,255,255,0.4);
    font-size: 11px;
  }
  @keyframes pulse-badge {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  @media (prefers-reduced-motion: reduce) {
    .badge-mega { animation: none; }
  }
</style>

<style is:global>
  .hero-77-punchy .countdown-unit {
    background: #DC2626 !important;
    border: 1px solid rgba(255,255,255,0.2);
  }
</style>
