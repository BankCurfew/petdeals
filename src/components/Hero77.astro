---
import CountdownTimer from './CountdownTimer.astro';

const saleEnd = '2026-07-08T00:00:00+07:00';
---

<section class="hero-77 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16 text-center relative z-10">
    <!-- Sale number -->
    <div class="sale-number select-none">7.7</div>
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 -mt-4">
      MEGA PET SALE
    </h2>
    <p class="text-lg text-white/80 mb-6">
      ลดสูงสุด 80% อุปกรณ์สัตว์เลี้ยง — ดีลดี ทาสต้องรีบ!
    </p>

    <!-- Countdown -->
    <div class="mb-8">
      <CountdownTimer targetDate={saleEnd} label="⏰ เหลืออีก" />
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/deals/7-7/" class="bg-white text-pet-600 px-6 py-3 rounded-full font-bold hover:bg-white/90 transition-colors shadow-lg">
        ดูดีล 7.7 ทั้งหมด
      </a>
      <a href="/categories/cats" class="bg-white/15 backdrop-blur text-white px-5 py-3 rounded-full font-medium border border-white/20 hover:bg-white/25 transition-colors">
        🐱 แมว
      </a>
      <a href="/categories/dogs" class="bg-white/15 backdrop-blur text-white px-5 py-3 rounded-full font-medium border border-white/20 hover:bg-white/25 transition-colors">
        🐕 สุนัข
      </a>
    </div>

    <!-- Mascot callout -->
    <div class="mt-6 inline-flex items-center gap-2 bg-white/10 backdrop-blur rounded-full px-4 py-2 text-white/90 text-sm">
      <img src="/brand/nong-deal-mascot.png" alt="น้องดีล" class="w-8 h-8 rounded-full object-cover" />
      <span>น้องดีล says: "ดีลดี ต้องรีบ meow!"</span>
    </div>
  </div>

  <!-- Decorative circles -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
</section>

<style>
  .hero-77 {
    background: linear-gradient(135deg, #FB7185 0%, #14B8A6 100%);
  }
  .sale-number {
    font-size: clamp(80px, 20vw, 140px);
    font-weight: 900;
    color: white;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    line-height: 1;
    letter-spacing: -0.02em;
  }
</style>
