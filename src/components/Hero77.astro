---
import CountdownTimer from './CountdownTimer.astro';
import productsData from '../../data/products.json';

const saleEnd = '2026-07-08T00:00:00+07:00';

const topDeals = productsData
  .filter((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const max = parseInt(String(p.priceMax).replace(/[^0-9]/g, '')) || 0;
    return max > price && p.slug;
  })
  .map((p: any) => {
    const price = parseInt(String(p.price).replace(/[^0-9]/g, '')) || 0;
    const max = parseInt(String(p.priceMax).replace(/[^0-9]/g, '')) || 0;
    return { ...p, priceNum: price, maxNum: max, discount: Math.round((1 - price / max) * 100) };
  })
  .sort((a: any, b: any) => b.discount - a.discount)
  .slice(0, 4);

const maxDiscount = topDeals.length > 0 ? topDeals[0].discount : 50;
---

<section class="hero-77 relative overflow-hidden">
  <!-- Animated background shapes -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-20 -left-20 w-80 h-80 bg-white/5 rounded-full animate-float-slow"></div>
    <div class="absolute -bottom-16 -right-16 w-64 h-64 bg-white/5 rounded-full animate-float-slow" style="animation-delay: -3s;"></div>
    <div class="absolute top-1/2 left-1/4 w-32 h-32 bg-white/3 rounded-full animate-float-slow" style="animation-delay: -5s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 pt-10 pb-8 md:pt-14 md:pb-10 relative z-10">
    <!-- Top: badge -->
    <div class="text-center mb-4">
      <span class="inline-block bg-white/20 backdrop-blur text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider animate-pulse">
        Flash Sale เริ่มแล้ว!
      </span>
    </div>

    <!-- Main: 7.7 + headline -->
    <div class="text-center mb-6">
      <div class="sale-number select-none">7.7</div>
      <h2 class="text-2xl md:text-4xl font-black text-white -mt-2 mb-2 tracking-tight">
        MEGA PET SALE
      </h2>
      <p class="text-xl md:text-2xl text-white font-bold">
        ลดสูงสุด <span class="text-yellow-300 text-3xl md:text-4xl">{maxDiscount}%</span>
      </p>
      <p class="text-white/70 text-sm mt-1">อุปกรณ์สัตว์เลี้ยง — ดีลดีที่ทาสต้องรีบ!</p>
    </div>

    <!-- Countdown -->
    <div class="text-center mb-8">
      <CountdownTimer targetDate={saleEnd} label="⏰ ดีลหมดใน" />
    </div>

    <!-- Flash deal preview cards -->
    {topDeals.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl mx-auto mb-8">
        {topDeals.map((deal: any) => (
          <a href={`/products/${deal.slug}`} class="bg-white/10 backdrop-blur rounded-xl p-3 text-center hover:bg-white/20 transition-colors group">
            <div class="aspect-square rounded-lg overflow-hidden bg-white/10 mb-2 relative">
              <img src={deal.images?.[0]} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
              <span class="absolute top-1 right-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">-{deal.discount}%</span>
            </div>
            <div class="text-red-300 font-bold text-sm">฿{deal.priceNum.toLocaleString()}</div>
            <div class="text-white/40 text-xs line-through">฿{deal.maxNum.toLocaleString()}</div>
          </a>
        ))}
      </div>
    )}

    <!-- CTA → article -->
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/blog/7-7-mega-sale-2026/" class="bg-yellow-400 text-gray-900 px-8 py-3.5 rounded-full font-black text-lg hover:bg-yellow-300 transition-colors shadow-lg shadow-yellow-400/30 animate-bounce-gentle">
        ดูดีล 7.7 ทั้งหมด →
      </a>
    </div>

    <!-- Mascot -->
    <div class="mt-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur rounded-full px-4 py-2 text-white/90 text-sm">
        <img src="/brand/nong-deal-bossy.png" alt="น้องดีล" class="w-8 h-8 rounded-full object-cover" />
        <span>น้องดีล: "ข้าคัดมาเอง จงกดเดี๋ยวนี้ เหมี๊ยว!"</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-77 {
    background: linear-gradient(135deg, #DC2626 0%, #FB7185 30%, #14B8A6 70%, #0D9488 100%);
  }
  .sale-number {
    font-size: clamp(90px, 22vw, 160px);
    font-weight: 900;
    color: white;
    text-shadow: 0 6px 30px rgba(0, 0, 0, 0.3), 0 2px 4px rgba(0,0,0,0.2);
    line-height: 0.9;
    letter-spacing: -0.03em;
  }
  @keyframes float-slow {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }
  .animate-float-slow { animation: float-slow 8s ease-in-out infinite; }
  @keyframes bounce-gentle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  .animate-bounce-gentle { animation: bounce-gentle 2s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .animate-float-slow, .animate-bounce-gentle, .animate-pulse { animation: none; }
  }
</style>
