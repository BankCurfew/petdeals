---
interface Props {
  code: string;
  discount: string;
  minSpend?: string;
  expiry?: string;
  affiliateUrl: string;
  productName?: string;
  persona?: string;
}

const { code, discount, minSpend, expiry, affiliateUrl, productName, persona } = Astro.props;
const voucherId = `voucher-${code.replace(/[^a-zA-Z0-9]/g, '')}`;
---

<div class="bg-amber-50 border border-amber-200 rounded-xl p-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-16 h-16 bg-amber-100 rounded-bl-[40px] flex items-end justify-start p-2">
    <span class="text-amber-400 text-lg">🏷️</span>
  </div>

  <p class="text-sm font-bold text-amber-800 mb-3">วิธีได้ราคานี้</p>

  <div class="flex items-center gap-2 mb-3">
    <div class="flex-1 bg-white rounded-lg px-3 py-2 border border-dashed border-amber-300 flex items-center justify-between">
      <span id={voucherId} class="font-mono font-bold text-orange-700 text-base tracking-wider">{code}</span>
      <button
        class="voucher-copy text-xs text-amber-600 hover:text-amber-800 px-2 py-1 rounded bg-amber-50 hover:bg-amber-100 transition-colors"
        data-code={code}
        data-target={voucherId}
        aria-label={`คัดลอกโค้ด ${code}`}
      >
        คัดลอก
      </button>
    </div>
  </div>

  <p class="text-sm font-medium text-amber-700 mb-2">ลด {discount}</p>
  {minSpend && <p class="text-xs text-amber-500 mb-1">ขั้นต่ำ {minSpend}</p>}
  {expiry && (
    <div class="flex items-center gap-1 text-xs text-amber-400 mb-3">
      <span>⏰</span>
      <span class="voucher-expiry" data-expiry={expiry}>หมดอายุ: {expiry}</span>
    </div>
  )}

  <ol class="text-sm text-amber-700 space-y-1 list-decimal list-inside mb-4">
    <li>กดปุ่มด้านล่างเพื่อไปหน้า Shopee</li>
    <li>ใส่โค้ด <strong>{code}</strong> ตอน checkout</li>
    <li>ได้ส่วนลดทันที!</li>
  </ol>

  <a
    href={affiliateUrl}
    target="_blank"
    rel="noopener sponsored"
    class="block w-full text-center bg-cta-500 text-white text-sm font-semibold py-3 rounded-full hover:bg-cta-600 transition-colors"
    data-affiliate="true"
    data-product-name={productName || ''}
    onclick={`window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'voucher_click',voucher_code:'${code}',persona:'${persona||''}',affiliate_url:'${affiliateUrl}'})`}
  >
    ใช้โค้ดนี้เลย
  </a>
</div>

<script is:inline>
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.voucher-copy');
    if (!btn) return;
    const code = btn.dataset.code;
    navigator.clipboard.writeText(code).then(() => {
      const orig = btn.textContent;
      btn.textContent = 'คัดลอกแล้ว ✓';
      btn.classList.add('text-green-600');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('text-green-600'); }, 2000);
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'voucher_copy', voucher_code: code });
    });
  });
</script>
