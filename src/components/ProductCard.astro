---
interface Props {
  name: string;
  image: string;
  price: number;
  originalPrice?: number;
  discount?: number;
  rating?: number | string;
  sold?: number | string;
  affiliateUrl: string;
  category?: string;
  lastUpdated?: string;
  slug?: string;
}

const { name, image: rawImage, price, originalPrice, discount, rating, sold, affiliateUrl, category, lastUpdated, slug } = Astro.props;
const image = (slug ? `/products/${slug}.webp` : '') || rawImage;

const formatPrice = (n: number) => `฿${n.toLocaleString('th-TH')}`;
const productPageUrl = slug ? `/products/${slug}` : null;
const formatDate = (d: string) => {
  const date = new Date(d);
  return date.toLocaleDateString('th-TH', { day: 'numeric', month: 'short' });
};
const ratingNum = typeof rating === 'string' ? parseFloat(rating) : rating;
const soldStr = typeof sold === 'string' ? sold : (sold && sold > 0 ? sold.toLocaleString() : '');
const hasRating = ratingNum != null && !isNaN(ratingNum) && ratingNum > 0;
const hasSold = !!soldStr && soldStr !== '0' && soldStr !== '';
---

<div class="group block bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200" data-product-category={category} data-product-name={name}>
  <!-- Image — links to product page -->
  <a href={productPageUrl || affiliateUrl} target={productPageUrl ? '_self' : '_blank'} rel={productPageUrl ? undefined : 'noopener sponsored'}>
    <div class="relative aspect-square bg-surface overflow-hidden">
      <img src={image} alt={name} title={name} width="400" height="400" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async" />
      {discount && discount > 0 && (
        <span class="absolute top-2 left-2 bg-coral-400 text-white text-xs font-bold px-2 py-0.5 rounded-md">
          -{discount}%
        </span>
      )}
    </div>
  </a>

  <!-- Info -->
  <div class="p-3">
    <a href={productPageUrl || affiliateUrl} target={productPageUrl ? '_self' : '_blank'} rel={productPageUrl ? undefined : 'noopener sponsored'}>
      <h3 class="text-sm text-gray-700 line-clamp-2 mb-2 group-hover:text-pet-500 transition-colors leading-snug">
        {name}
      </h3>
    </a>

    <!-- Price -->
    <div class="flex items-baseline flex-wrap gap-1.5 mb-2">
      <span class:list={['text-lg font-bold', originalPrice != null && originalPrice > price ? 'text-red-500' : 'text-pet-600']}>
        {formatPrice(price)}
      </span>
      {originalPrice && originalPrice > price && (
        <span class="text-xs text-gray-400 line-through">{formatPrice(originalPrice)}</span>
      )}
      {discount != null && discount > 0 && (
        <span class="text-[10px] font-bold text-red-500 bg-red-50 px-1.5 py-0.5 rounded">-{discount}%</span>
      )}
    </div>

    <!-- Rating + Sold -->
    {(hasRating || hasSold) && (
      <div class="flex items-center gap-3 text-xs text-gray-400">
        {hasRating && (
          <span class="flex items-center gap-0.5">
            <span class="text-star">★</span> {ratingNum!.toFixed(1)}
          </span>
        )}
        {hasSold && <span>ขายแล้ว {soldStr}</span>}
      </div>
    )}

    <!-- Last Updated -->
    {lastUpdated && (
      <p class="text-[10px] text-gray-300 mt-1">อัพเดท: {formatDate(lastUpdated)}</p>
    )}

    <!-- CTA -->
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener sponsored"
      class="mt-3 block w-full text-center bg-cta-500 text-white text-sm font-medium py-2 rounded-full hover:bg-cta-600 transition-colors"
      data-affiliate="true"
      data-product-name={name}
      data-product-price={price}
      data-product-category={category}
      onclick={`window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'affiliate_click',product_name:'${name.replace(/'/g,"\\'")}',product_price:${price},product_category:'${category||''}',affiliate_url:'${affiliateUrl}'})`}
    >
      เช็คราคาให้เจ้านาย
    </a>
  </div>
</div>
