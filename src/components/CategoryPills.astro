---
import categoriesData from '../../data/categories.json';

const activeCats = categoriesData.filter((c: any) => c.phase === 1);
---

<div class="flex gap-2 overflow-x-auto scrollbar-hide py-2 px-4 -mx-4" style="scrollbar-width: none;" id="filter-pills">
  <!-- All filter -->
  <button
    type="button"
    data-filter="all"
    class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap flex-shrink-0 border transition-colors cursor-pointer bg-pet-500 text-white border-pet-500"
  >
    ทั้งหมด
  </button>

  <!-- Category pills from data -->
  {activeCats.map((cat: any) => (
    <button
      type="button"
      data-filter={cat.dataCategory}
      data-href={`/categories/${cat.slug}/`}
      class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap flex-shrink-0 border transition-colors cursor-pointer bg-surface text-gray-600 border-gray-100 hover:bg-pet-50 hover:text-pet-600"
    >
      {cat.emoji} {cat.name}
    </button>
  ))}
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll('.filter-pill');
    const cards = document.querySelectorAll('[data-product-category]');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter;

        // If on homepage (has product cards), filter inline
        if (cards.length > 0) {
          pills.forEach(p => {
            p.classList.remove('bg-pet-500', 'text-white', 'border-pet-500');
            p.classList.add('bg-surface', 'text-gray-600', 'border-gray-100');
          });
          pill.classList.remove('bg-surface', 'text-gray-600', 'border-gray-100');
          pill.classList.add('bg-pet-500', 'text-white', 'border-pet-500');

          cards.forEach(card => {
            if (filter === 'all' || card.dataset.productCategory === filter) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        } else if (pill.dataset.href) {
          // On other pages, navigate to category page
          window.location.href = pill.dataset.href;
        }
      });
    });
  });
</script>
