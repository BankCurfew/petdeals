---
interface Props {
  href: string;
  variant?: 'default' | 'bossy';
}

const { href, variant = 'default' } = Astro.props;

const phrases = [
  'จงกดซื้อให้ข้าเดี๋ยวนี้ เหมี๊ยว!',
  'เด็ดมาอีกแล้วเจ้าทาส!',
  'ของดี ข้าคัดมาเอง เหมียว~',
  'กดเลยเจ้าทาส ไม่ต้องคิด!',
  'ข้าสั่ง! จงเช็คราคา!',
];
const phraseIndex = Math.floor(href.length % phrases.length);
const text = phrases[phraseIndex];
---

<div class="speech-bubble-wrapper">
  <a
    href={href}
    target="_blank"
    rel="noopener sponsored"
    class="speech-bubble-cta"
    data-affiliate="true"
  >
    {text}
  </a>
</div>

<style>
  .speech-bubble-wrapper {
    display: inline-block;
    position: relative;
  }
  .speech-bubble-cta {
    display: inline-block;
    background: #22C55E;
    color: white;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 24px;
    position: relative;
    font-family: 'Sarabun', sans-serif;
    font-size: 15px;
    transition: all 0.2s;
    text-decoration: none;
  }
  .speech-bubble-cta::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%);
    border: 8px solid transparent;
    border-right-color: #22C55E;
  }
  .speech-bubble-cta:hover {
    background: #16A34A;
    transform: scale(1.03);
  }
  .speech-bubble-cta:hover::before {
    border-right-color: #16A34A;
  }
</style>
