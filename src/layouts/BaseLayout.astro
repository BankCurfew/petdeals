---
import NongDealCorner from '@/components/NongDealCorner.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, description = 'PetzDeals — รวมดีลอุปกรณ์สัตว์เลี้ยงราคาดี คัดมาให้ทาสแมวและทาสหมาโดยเฉพาะ', image, type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image || '/brand/og-default.webp', Astro.site).href;
---

<!doctype html>
<html lang="th">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MXZC4NXN');</script>
  <!-- GA4 gtag.js -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-3TCK9V54XS"></script>
  <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-3TCK9V54XS');</script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="th_TH" />
  <meta property="og:site_name" content="PetzDeals" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{title} | PetzDeals</title>
</head>
<body class="bg-white text-gray-800 font-sans antialiased">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MXZC4NXN" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100 relative overflow-visible">
    <!-- Cat tail peeking from header -->
    <div class="header-tail" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🐾</span>
        <span class="text-lg font-bold"><span class="text-pet-700">Petz</span><span class="text-coral-500">Deals</span></span>
      </a>
      <!-- Search Bar -->
      <div class="hidden sm:block flex-1 max-w-xs mx-4">
        <div class="relative">
          <input
            type="search"
            id="site-search"
            placeholder="ค้นหาสินค้า..."
            class="w-full pl-9 pr-3 py-1.5 text-sm border border-gray-200 rounded-full bg-gray-50 focus:bg-white focus:border-pet-400 focus:outline-none transition-colors"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
      </div>
      <nav class="hidden md:flex items-center gap-6 text-sm text-gray-600">
        <a href="/" class="hover:text-pet-500 transition-colors">หน้าแรก</a>
        <a href="/deals/today/" class="hover:text-pet-500 transition-colors">ดีลเด็ด</a>
        <a href="/deals/7-7/" class="hover:text-pet-500 transition-colors">ดีล 7.7</a>
        <a href="/blog" class="hover:text-pet-500 transition-colors">บทความ</a>
      </nav>
      <div class="flex items-center gap-2">
        <a href="/deals/7-7/" class="bg-cta-500 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-cta-600 transition-colors">
          ดูดีล 7.7
        </a>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600" aria-label="เมนู">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3">
      <div class="relative mb-3">
        <input type="search" id="mobile-search" placeholder="ค้นหาสินค้า..." class="w-full pl-9 pr-3 py-2 text-sm border border-gray-200 rounded-full bg-gray-50 focus:bg-white focus:border-pet-400 focus:outline-none" />
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <nav class="flex flex-col gap-2 text-sm">
        <a href="/" class="px-3 py-2 rounded-lg hover:bg-pet-50 text-gray-700">หน้าแรก</a>
        <a href="/deals/today/" class="px-3 py-2 rounded-lg hover:bg-pet-50 text-gray-700">ดีลเด็ดวันนี้</a>
        <a href="/deals/7-7/" class="px-3 py-2 rounded-lg hover:bg-pet-50 text-pet-600 font-medium">ดีล 7.7 Mega Sale</a>
        <a href="/blog" class="px-3 py-2 rounded-lg hover:bg-pet-50 text-gray-700">บทความรีวิว</a>
      </nav>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <!-- น้องดีล corner mascot -->
  <NongDealCorner />

  <!-- Footer -->
  <footer class="bg-gray-50 border-t border-gray-100 py-12 mt-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl">🐾</span>
            <span class="text-lg font-bold"><span class="text-pet-700">Petz</span><span class="text-coral-500">Deals</span></span>
          </div>
          <p class="text-sm text-gray-500">คัดดีลอุปกรณ์สัตว์เลี้ยงราคาดี สำหรับทาสแมวและทาสหมาตัวจริง อัพเดททุกวัน</p>
        </div>
        <div>
          <p class="font-semibold text-sm mb-3">หมวดหมู่</p>
          <ul class="space-y-2 text-sm text-gray-500">
            <li><a href="/categories/food" class="hover:text-pet-500">อาหาร</a></li>
            <li><a href="/categories/toys" class="hover:text-pet-500">ของเล่น</a></li>
            <li><a href="/categories/accessories" class="hover:text-pet-500">อุปกรณ์</a></li>
            <li><a href="/categories/health" class="hover:text-pet-500">สุขภาพ</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-sm mb-3">เกี่ยวกับเรา</p>
          <ul class="space-y-2 text-sm text-gray-500">
            <li><a href="/about" class="hover:text-pet-500">เกี่ยวกับ PetzDeals</a></li>
            <li><a href="/blog" class="hover:text-pet-500">บทความ</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-200 mt-8 pt-6 text-center text-xs text-gray-400">
        <p>&copy; 2026 PetzDeals — petzdeals.com</p>
        <p class="mt-1">ราคาและส่วนลดอาจเปลี่ยนแปลงได้ กรุณาตรวจสอบราคาล่าสุดก่อนสั่งซื้อ</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (menuBtn && menu) {
        menuBtn.addEventListener('click', () => menu.classList.toggle('hidden'));
      }

      // Search (desktop + mobile)
      ['site-search', 'mobile-search'].forEach(id => {
        const search = document.getElementById(id);
        if (search) {
          search.addEventListener('input', (e) => {
            const q = e.target.value.toLowerCase().trim();
            document.querySelectorAll('[data-product-name]').forEach(card => {
              card.style.display = (!q || card.dataset.productName.toLowerCase().includes(q)) ? '' : 'none';
            });
          });
        }
      });

      // Track ALL affiliate link clicks site-wide
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href*="s.shopee.co.th"], a[href*="shope.ee"]');
        if (!link) return;
        const article = document.querySelector('article');
        const articleSlug = window.location.pathname.replace(/\//g, '').replace('blog', '') || 'homepage';
        const card = link.closest('[data-product-name]');
        const productName = card?.dataset.productName || link.title || link.closest('a')?.title || '';
        const isInline = !!link.closest('.blog-article, .prose');
        const isCTA = link.classList.contains('bg-cta-500') || link.textContent.includes('เช็คราคา');
        const isCard = !!card;
        const position = isCTA ? 'cta' : isCard ? 'card' : isInline ? 'inline' : 'other';
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'affiliate_click',
          article_slug: articleSlug,
          product_name: productName,
          link_position: position,
          link_url: link.href,
          page_type: document.querySelector('.blog-article') ? 'article' : document.querySelector('[data-product-name]') ? 'product' : 'page'
        });
      });

      // Scroll depth tracking for articles
      if (document.querySelector('.blog-article')) {
        let maxScroll = 0;
        const milestones = [25, 50, 75, 100];
        const fired = new Set();
        window.addEventListener('scroll', () => {
          const doc = document.documentElement;
          const pct = Math.round((window.scrollY / (doc.scrollHeight - doc.clientHeight)) * 100);
          if (pct > maxScroll) maxScroll = pct;
          milestones.forEach(m => {
            if (pct >= m && !fired.has(m)) {
              fired.add(m);
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'scroll_depth',
                scroll_pct: m,
                article_slug: window.location.pathname
              });
            }
          });
        });
      }
    });
  </script>

  <style is:global>
    .header-tail {
      position: absolute;
      right: 140px;
      top: -2px;
      width: 32px;
      height: 40px;
      background: url('/brand/cat-tail.svg') no-repeat center;
      background-size: contain;
      animation: tail-wag 2s ease-in-out infinite;
      pointer-events: none;
      z-index: 51;
    }
    @keyframes tail-wag {
      0%, 100% { transform: rotate(0deg); }
      33% { transform: rotate(10deg); }
      66% { transform: rotate(-10deg); }
    }
    @media (max-width: 768px) {
      .header-tail { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .header-tail { animation: none; }
    }
  </style>
</body>
</html>
